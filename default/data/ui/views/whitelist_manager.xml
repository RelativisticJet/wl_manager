<dashboard version="1.1" theme="dark" script="whitelist_manager.js" stylesheet="whitelist_manager.css">
  <label>Whitelist Manager</label>
  <description>View, edit, and audit detection-rule CSV whitelists</description>

  <!-- ============================================================
       EDITABLE CSV TABLE  (rendered by whitelist_manager.js)
       ============================================================ -->
  <row>
    <panel>
      <html>
        <div id="wl-dropdowns">
          <div class="wl-dropdown-group">
            <label class="wl-dropdown-label">Detection Rule</label>
            <div class="wl-search-select" id="rule-select">
              <input type="text" class="wl-search-input" id="rule-search"
                     placeholder="Type to search detection rules..." autocomplete="off" />
              <div class="wl-dropdown-list" id="rule-list"></div>
            </div>
          </div>
          <div class="wl-dropdown-group">
            <label class="wl-dropdown-label">CSV File</label>
            <select class="wl-select" id="csv-select" disabled="disabled">
              <option value="">-- Select a Detection Rule first --</option>
            </select>
          </div>
        </div>
        <div id="message-container"></div>
        <div id="csv-table-container">
          <p class="wl-muted">Select a detection rule and CSV file above.</p>
        </div>
        <div id="diff-container"></div>
      </html>
    </panel>
  </row>

</dashboard>
