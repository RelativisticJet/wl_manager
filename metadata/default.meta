#
# Permissions for the Whitelist Manager app.
#
# wl_editor / admin / sc_admin  — full read+write
# wl_viewer                     — read-only (can view dashboards + audit)
# *                             — no access by default
#

[]
access = read : [ wl_editor, wl_viewer, admin, sc_admin ], write : [ admin, sc_admin ]
export = system
owner = admin

[views]
access = read : [ wl_editor, wl_viewer, admin, sc_admin ], write : [ admin, sc_admin, wl_editor ]
export = system
owner = admin

[views/audit]
access = read : [ wl_editor, wl_viewer, admin, sc_admin ], write : [ admin, sc_admin, wl_editor ]
export = system
owner = admin

[views/whitelist_manager]
access = read : [ wl_editor, wl_viewer, admin, sc_admin ], write : [ admin, sc_admin, wl_editor ]
export = system
owner = admin

[lookups]
access = read : [ wl_editor, wl_viewer, admin, sc_admin ], write : [ admin, sc_admin, wl_editor ]
export = system

[transforms]
access = read : [ wl_editor, wl_viewer, admin, sc_admin ], write : [ admin, sc_admin ]
export = system
