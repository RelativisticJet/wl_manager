#!/usr/bin/env bash
# Pre-commit hook for Whitelist Manager
# Prevents common issues from being committed.
#
# Install: copy to .git/hooks/pre-commit (or symlink scripts/pre-commit)
# Skip:    git commit --no-verify (use sparingly)

set -e

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

ERRORS=0

# Get list of staged files
STAGED=$(git diff --cached --name-only --diff-filter=ACM)

# ── 1. Block CLAUDE.md from being committed ──
if echo "$STAGED" | grep -qE '^CLAUDE\.md$'; then
    echo -e "${RED}BLOCKED:${NC} CLAUDE.md is staged for commit."
    echo "  This file contains internal development notes and must not be committed."
    echo "  Run: git reset HEAD CLAUDE.md"
    ERRORS=$((ERRORS + 1))
fi

# ── 2. Block .env files ──
if echo "$STAGED" | grep -qE '\.env$|\.env\.local$|\.env\.production$'; then
    echo -e "${RED}BLOCKED:${NC} .env file staged for commit."
    echo "  Environment files may contain secrets."
    ERRORS=$((ERRORS + 1))
fi

# ── 3. Check for console.log in production JS ──
JS_FILES=$(echo "$STAGED" | grep -E 'appserver/static/.*\.js$' | grep -v 'node_modules\|tests/' || true)
if [ -n "$JS_FILES" ]; then
    for f in $JS_FILES; do
        if git show ":$f" 2>/dev/null | grep -n 'console\.log\|console\.info\|console\.debug' | grep -v '//.*console' > /dev/null 2>&1; then
            echo -e "${YELLOW}WARNING:${NC} console.log found in $f"
            git show ":$f" | grep -n 'console\.log\|console\.info\|console\.debug' | grep -v '//.*console' | head -5
            ERRORS=$((ERRORS + 1))
        fi
    done
fi

# ── 4. Check for debugger statements in JS ──
if [ -n "$JS_FILES" ]; then
    for f in $JS_FILES; do
        if git show ":$f" 2>/dev/null | grep -n '^\s*debugger' > /dev/null 2>&1; then
            echo -e "${RED}BLOCKED:${NC} debugger statement in $f"
            ERRORS=$((ERRORS + 1))
        fi
    done
fi

# ── 5. Python syntax check on staged .py files ──
PY_FILES=$(echo "$STAGED" | grep -E '\.py$' || true)
if [ -n "$PY_FILES" ]; then
    for f in $PY_FILES; do
        if ! python3 -m py_compile "$f" 2>/dev/null; then
            echo -e "${RED}BLOCKED:${NC} Python syntax error in $f"
            python3 -m py_compile "$f" 2>&1 || true
            ERRORS=$((ERRORS + 1))
        fi
    done
fi

# ── 6. Check for hardcoded passwords in staged files ──
for f in $STAGED; do
    if git show ":$f" 2>/dev/null | grep -inE 'password\s*=\s*["\x27][^"\x27]+["\x27]|api_key\s*=\s*["\x27][^"\x27]+["\x27]' | grep -v 'placeholder\|example\|SPLUNK_PASSWORD\|os\.environ\|\.get(' > /dev/null 2>&1; then
        # Exclude known safe patterns (docker-compose defaults, test fixtures, documentation)
        case "$f" in
            docker-compose*|Makefile|README*|CONTRIBUTING*|docs/*|tests/*|demo/*) ;;
            *)
                echo -e "${YELLOW}WARNING:${NC} Possible hardcoded credential in $f"
                ERRORS=$((ERRORS + 1))
                ;;
        esac
    fi
done

# ── 7. Documentation drift guard ──
# Runs only when a doc covered by the guard is staged (avoids slowing down
# pure code commits). See scripts/pre-commit-doc-drift.sh for the policy.
DOC_CHANGES=$(echo "$STAGED" | grep -E '^(CLAUDE|README|CONTRIBUTING|ARCHITECTURE|INSTALLATION|SECURITY|CODE_OF_CONDUCT|CHANGELOG)\.md$|^docs/.*\.md$|^default/app\.conf$' || true)
if [ -n "$DOC_CHANGES" ]; then
    REPO_ROOT=$(git rev-parse --show-toplevel)
    if ! bash "$REPO_ROOT/scripts/pre-commit-doc-drift.sh"; then
        ERRORS=$((ERRORS + 1))
    fi
fi

# ── 8. ASCII-validator drift guard ──
# Background: 2026-04-26 incident — c.isalnum() is Unicode-aware in
# Python and accepted CJK ideographs as "letters", silently making the
# rule-name validator a no-op for the homoglyph attacks we care about.
# Replaced by is_ascii_name() / c.isascii() and c.isalnum() patterns
# in wl_validation.py. This guard catches anyone re-introducing the bare
# c.isalnum() pattern in a security-sensitive path under bin/.
#
# Allowed: c.isascii() and c.isalnum() (this is the corrected pattern)
# Allowed: comment-only mentions (the # appears before the call)
# Allowed: any usage in tests/ or in non-validation contexts via marker
# Banned : c.isalnum() in a code statement with no isascii() check
BIN_PY_FILES=$(echo "$STAGED" | grep -E '^bin/.*\.py$' || true)
if [ -n "$BIN_PY_FILES" ]; then
    for f in $BIN_PY_FILES; do
        # Pull staged content; grep for .isalnum() with these exclusions:
        #   - ASCII-OK marker on same line (intentional non-security use)
        #   - isascii() check on same line (the corrected pattern)
        #   - mention inside a comment (the # comes before .isalnum)
        if git show ":$f" 2>/dev/null | grep -nE '\.isalnum\(\)' \
            | grep -vE 'isascii\(\).*isalnum\(\)|# ASCII-OK|^[0-9]+:[[:space:]]*#|#[^#]*\.isalnum' \
            > /tmp/wl_isalnum_hits.txt 2>/dev/null; then
            if [ -s /tmp/wl_isalnum_hits.txt ]; then
                echo -e "${RED}BLOCKED:${NC} bare .isalnum() found in $f"
                echo "  Python's str.isalnum() is Unicode-aware and accepts CJK,"
                echo "  Cyrillic, Greek, etc. as 'letters'. Use the ASCII-strict"
                echo "  pattern instead: 'c.isascii() and c.isalnum()'"
                echo "  Or call is_ascii_name() / is_safe_filename() from wl_validation."
                echo "  If this usage is intentional and not a security gate,"
                echo "  add the trailing comment '# ASCII-OK' on the same line."
                cat /tmp/wl_isalnum_hits.txt | head -5
                ERRORS=$((ERRORS + 1))
            fi
            rm -f /tmp/wl_isalnum_hits.txt
        fi
    done
fi

# ── Result ──
if [ $ERRORS -gt 0 ]; then
    echo ""
    echo -e "${RED}Pre-commit check failed with $ERRORS issue(s).${NC}"
    echo "Fix the issues above, or use 'git commit --no-verify' to bypass."
    exit 1
fi

exit 0
